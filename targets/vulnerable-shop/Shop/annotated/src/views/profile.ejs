<%- include('partials/header', { title: 'Profile — VulnShop' }) %>

<h1>My Profile</h1>

<section class="card">
  <h2>Account Details</h2>
  <form id="profileForm" action="/api/profile/update" method="POST">
    <div class="form-group">
      <label>Username</label>
      <input type="text" name="username" value="<%= user.username %>">
    </div>
    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" value="<%= user.email %>">
    </div>
    <button type="submit" class="btn btn-primary">Save Changes</button>
  </form>
</section>

<section class="card">
  <h2>Avatar</h2>
  <% if (user.avatar) { %>
    <img src="/api/avatar/<%= user.avatar %>" alt="Avatar" class="avatar-preview">
  <% } %>
  <form action="/api/profile/avatar" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <input type="file" name="avatar" accept="image/*">
    </div>
    <button type="submit" class="btn btn-secondary">Upload Avatar</button>
  </form>
</section>

<section class="card">
  <h2>Import Cart</h2>
  <form id="cartImportForm">
    <div class="form-group">
      <label>Cart Data (base64)</label>
      <textarea name="cartData" rows="3" placeholder="Paste exported cart data..."></textarea>
    </div>
    <button type="submit" class="btn btn-secondary">Import Cart</button>
  </form>
</section>

<script>
document.getElementById('cartImportForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const data = Object.fromEntries(new FormData(e.target));
  const r = await fetch('/api/cart/import', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  });
  const res = await r.json();
  alert(r.ok ? `Cart imported: ${res.itemCount} items` : res.error);
});
</script>

<%- include('partials/footer') %>
